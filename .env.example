# DrawMind3D - API Configuration
# Copy this file to .env and fill in your API key

# OpenRouter API key (access Claude, GPT-4o, Llama etc. through one API)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Override default models (use OpenRouter model IDs)
# See available models: https://openrouter.ai/models
# VISION_MODEL=anthropic/claude-sonnet-4-20250514
# TEXT_MODEL=anthropic/claude-haiku-4-5-20251001
# VISION_MODEL=openai/gpt-4o
# TEXT_MODEL=openai/gpt-4o-mini
